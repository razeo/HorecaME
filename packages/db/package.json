{
  "name": "@horecame/db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./queries": {
      "types": "./src/queries/index.ts",
      "default": "./src/queries/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "supabase gen types typescript --local > src/types.ts",
    "db:migrate": "supabase migration up",
    "db:seed": "psql $DATABASE_URL -f supabase/seed.sql"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0"
  },
  "devDependencies": {
    "@horecame/tsconfig": "workspace:*",
    "@horecame/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
